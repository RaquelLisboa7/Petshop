// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  atendente
  cliente
}

enum AgendamentoStatus {
  criado
  confirmado
  cancelado
}


model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role   @default(cliente)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  refreshTokens RefreshToken[]
  agendamentos   Agendamento[]
  atendimentos   Atendimento[]
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  tokenHash  String   @unique
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
}

enum AtendimentoStatus {
  agendado
  confirmado
  em_atendimento
  finalizado
  cancelado
}

model Atendimento {
  id             Int                @id @default(autoincrement())
  status         AtendimentoStatus  @default(agendado)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  userId         Int
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  agendamentoId  Int                @unique
  agendamento    Agendamento        @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

model Agendamento {
  id           Int                @id @default(autoincrement())
  userId       Int
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataHora     DateTime
  status       AgendamentoStatus  @default(criado)
  atendimento  Atendimento?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}